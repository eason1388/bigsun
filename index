<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>大森旅遊｜機場接送 × 台灣旅遊</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  /* Blue sky palette */
  --sky1:#0A74C8;   /* deep sky */
  --sky2:#1A9FE0;   /* mid sky */
  --sky3:#5BC5F5;   /* light sky */
  --cloud:#F0F8FF;  /* cloud white-blue */
  --white:#FFFFFF;
  --bg:#F5FBFF;
  /* Accent */
  --sun:#F5A623;
  --sun2:#E8830A;
  /* Text — always dark on light, white on dark */
  --text:#0D1B2A;
  --text2:#2C4A6E;
  --text3:#5A7A9A;
  --border:#C5DFF5;
  --radius:14px;
  --shadow:0 4px 20px rgba(10,116,200,.12);
}
html,body{height:100%;font-family:'Microsoft JhengHei','Segoe UI',sans-serif;background:var(--bg);color:var(--text)}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}

/* ─── TOP NAV ─── */
.topbar{
  position:fixed;top:0;left:0;right:0;z-index:200;
  background:var(--white);
  border-bottom:3px solid var(--sky1);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 32px;height:62px;
  box-shadow:0 2px 16px rgba(10,116,200,.1);
}
.logo{display:flex;align-items:center;gap:10px;font-size:1.3rem;font-weight:900;color:var(--text)}
.logo-box{
  width:40px;height:40px;border-radius:10px;
  background:linear-gradient(135deg,var(--sky1),var(--sky2));
  display:flex;align-items:center;justify-content:center;font-size:1.3rem;
  box-shadow:0 3px 10px rgba(10,116,200,.3);
}
.logo em{color:var(--sky1);font-style:normal}
.nav-tabs{display:flex;height:62px}
.nav-tab{
  display:flex;align-items:center;padding:0 18px;
  font-size:.88rem;font-weight:700;color:var(--text2);
  border-bottom:3px solid transparent;cursor:pointer;
  white-space:nowrap;transition:color .15s,border-color .15s;
}
.nav-tab:hover{color:var(--sky1)}
.nav-tab.active{color:var(--sky1);border-bottom-color:var(--sky1)}
.nav-book{
  background:linear-gradient(135deg,var(--sky1),var(--sky2));
  color:#fff;font-weight:800;padding:9px 22px;border-radius:50px;
  font-size:.88rem;cursor:pointer;border:none;
  box-shadow:0 3px 12px rgba(10,116,200,.35);
  transition:transform .15s,box-shadow .15s;white-space:nowrap;
}
.nav-book:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(10,116,200,.45)}
@media(max-width:900px){.nav-tabs{display:none}.topbar{padding:0 16px}}

/* ─── PAGE SYSTEM ─── */
.page{display:none;padding-top:62px;min-height:100vh}
.page.active{display:block}

/* ═══════════════════════════════
   HOME PAGE
═══════════════════════════════ */
/* Hero */
.hero{
  min-height:calc(100vh - 62px);
  display:flex;align-items:center;
  position:relative;overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;
  background:
    linear-gradient(160deg,rgba(10,116,200,.78) 0%,rgba(26,159,224,.6) 50%,rgba(91,197,245,.35) 100%),
    url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=1600&q=80') center/cover no-repeat;
}
.hero-content{position:relative;z-index:1;max-width:660px;padding:48px 40px}
.hero-pill{
  display:inline-flex;align-items:center;gap:6px;
  padding:6px 18px;border-radius:50px;
  background:rgba(255,255,255,.22);border:1.5px solid rgba(255,255,255,.55);
  color:#fff;font-size:.85rem;font-weight:700;margin-bottom:22px;
}
.hero h1{
  font-size:clamp(2rem,5vw,3.6rem);font-weight:900;
  color:#fff;line-height:1.15;margin-bottom:18px;
  text-shadow:0 2px 16px rgba(0,0,0,.25);
}
.hero h1 strong{color:#FFE566}
.hero p{font-size:1.05rem;color:rgba(255,255,255,.93);line-height:1.8;margin-bottom:32px}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap}
.btn-white{
  display:inline-block;padding:12px 28px;border-radius:50px;
  background:#fff;color:var(--sky1);font-weight:800;font-size:.92rem;
  box-shadow:0 4px 16px rgba(0,0,0,.15);transition:transform .15s;
}
.btn-white:hover{transform:translateY(-2px)}
.btn-ghost{
  display:inline-block;padding:11px 28px;border-radius:50px;
  border:2px solid rgba(255,255,255,.75);color:#fff;font-weight:700;font-size:.92rem;
  transition:background .15s;
}
.btn-ghost:hover{background:rgba(255,255,255,.18)}
.hero-stats{display:flex;gap:28px;margin-top:44px;flex-wrap:wrap}
.hs h3{font-size:1.9rem;font-weight:900;color:#FFE566}
.hs p{color:rgba(255,255,255,.88);font-size:.8rem;margin-top:1px}
.hero-wave{position:absolute;bottom:-1px;left:0;right:0;z-index:2;line-height:0}
.hero-wave svg{display:block;width:100%}

/* Quick nav grid */
.quick-section{background:var(--white);padding:44px 32px 52px}
.quick-section h2{text-align:center;font-size:1.4rem;font-weight:900;color:var(--text);margin-bottom:6px}
.quick-section p{text-align:center;color:var(--text3);font-size:.9rem;margin-bottom:28px}
.quick-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:14px;max-width:1050px;margin:0 auto}
.qc{
  background:var(--bg);border:2px solid var(--border);border-radius:var(--radius);
  padding:26px 16px;text-align:center;cursor:pointer;
  transition:transform .2s,border-color .2s,box-shadow .2s;
}
.qc:hover{transform:translateY(-4px);border-color:var(--sky2);box-shadow:0 8px 24px rgba(10,116,200,.14)}
.qc-icon{font-size:2rem;margin-bottom:10px}
.qc-title{font-size:.95rem;font-weight:800;color:var(--text);margin-bottom:4px}
.qc-sub{font-size:.78rem;color:var(--text3)}

/* Home photo strip */
.photo-strip{background:var(--cloud);padding:52px 32px}
.photo-strip-head{text-align:center;margin-bottom:32px}
.photo-strip-head h2{font-size:1.5rem;font-weight:900;color:var(--text);margin-bottom:6px}
.photo-strip-head p{color:var(--text3);font-size:.9rem}
.photo-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr;grid-template-rows:220px 220px;gap:12px;max-width:1050px;margin:0 auto}
.photo-item{border-radius:12px;overflow:hidden;position:relative;cursor:pointer}
.photo-item.tall{grid-row:1/3}
.photo-item img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s}
.photo-item:hover img{transform:scale(1.06)}
.photo-caption{
  position:absolute;bottom:0;left:0;right:0;padding:14px 16px;
  background:linear-gradient(to top,rgba(10,30,60,.8),transparent);
  color:#fff;font-size:.88rem;font-weight:700;
}
.photo-caption small{display:block;font-size:.72rem;font-weight:400;color:rgba(255,255,255,.8);margin-top:1px}
@media(max-width:700px){
  .photo-grid{grid-template-columns:1fr 1fr;grid-template-rows:auto}
  .photo-item.tall{grid-row:auto}
}

/* Home service teaser */
.home-services{background:var(--white);padding:52px 32px}
.hs-inner{max-width:1050px;margin:0 auto}
.hs-head{text-align:center;margin-bottom:32px}
.hs-head h2{font-size:1.5rem;font-weight:900;color:var(--text);margin-bottom:6px}
.hs-head p{color:var(--text3);font-size:.9rem}
.hs-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px}
.hsc{
  display:flex;align-items:flex-start;gap:14px;
  background:var(--bg);border:1.5px solid var(--border);border-radius:12px;padding:20px;
  transition:border-color .2s,box-shadow .2s;
}
.hsc:hover{border-color:var(--sky2);box-shadow:var(--shadow)}
.hsc-icon{
  width:44px;height:44px;flex-shrink:0;border-radius:10px;
  background:linear-gradient(135deg,var(--sky1),var(--sky2));
  display:flex;align-items:center;justify-content:center;font-size:1.25rem;
}
.hsc h4{font-size:.95rem;font-weight:800;color:var(--text);margin-bottom:4px}
.hsc p{font-size:.82rem;color:var(--text2);line-height:1.65}

/* CTA strip on home */
.home-cta{
  background:linear-gradient(135deg,var(--sky1),var(--sky2));
  padding:52px 32px;text-align:center;
}
.home-cta h2{font-size:1.6rem;font-weight:900;color:#fff;margin-bottom:10px}
.home-cta p{color:rgba(255,255,255,.9);font-size:.95rem;margin-bottom:28px}
.home-cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.btn-cta-w{display:inline-block;padding:12px 28px;border-radius:50px;background:#fff;color:var(--sky1);font-weight:800;box-shadow:0 3px 14px rgba(0,0,0,.15);transition:transform .15s}
.btn-cta-w:hover{transform:translateY(-2px)}
.btn-cta-g{display:inline-block;padding:11px 28px;border-radius:50px;border:2px solid rgba(255,255,255,.8);color:#fff;font-weight:700;transition:background .15s}
.btn-cta-g:hover{background:rgba(255,255,255,.18)}

/* ─── SHARED PAGE STYLES ─── */
.page-header{
  padding:44px 32px 40px;text-align:center;
  background:linear-gradient(135deg,var(--sky1) 0%,var(--sky2) 100%);
}
.page-header h1{font-size:clamp(1.6rem,4vw,2.4rem);font-weight:900;color:#fff;text-shadow:0 2px 10px rgba(0,0,0,.18)}
.page-header p{color:rgba(255,255,255,.92);margin-top:10px;font-size:.95rem;max-width:540px;margin-left:auto;margin-right:auto;line-height:1.7}

.content{max-width:1050px;margin:0 auto;padding:44px 24px 60px}

/* Labels */
.label{font-size:.75rem;font-weight:800;color:var(--sky1);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px}
.title{font-size:clamp(1.3rem,3vw,1.9rem);font-weight:900;color:var(--text);margin-bottom:10px}
.sub{font-size:.9rem;color:var(--text2);line-height:1.75;max-width:580px}

.divider{height:1px;background:var(--border);margin:40px 0}

/* Grids */
.g2{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px}
.g3{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:18px}
.g4{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px}

/* ─── SERVICE CARDS ─── */
.svc-card{background:var(--white);border-radius:var(--radius);overflow:hidden;border:1.5px solid var(--border);box-shadow:var(--shadow);transition:transform .2s,box-shadow .2s}
.svc-card:hover{transform:translateY(-5px);box-shadow:0 12px 32px rgba(10,116,200,.18)}
.svc-img{height:190px;overflow:hidden}
.svc-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.svc-card:hover .svc-img img{transform:scale(1.06)}
.svc-body{padding:20px}
.svc-icon{width:42px;height:42px;border-radius:10px;margin-bottom:11px;background:linear-gradient(135deg,var(--sky1),var(--sky2));display:flex;align-items:center;justify-content:center;font-size:1.2rem}
.svc-body h3{font-size:1rem;font-weight:800;color:var(--text);margin-bottom:6px}
.svc-body p{font-size:.85rem;color:var(--text2);line-height:1.75}
.svc-tag{display:inline-block;margin-top:11px;padding:3px 11px;border-radius:50px;background:#E3F3FD;color:var(--sky1);font-size:.74rem;font-weight:800}

/* ─── WHY US ─── */
.why-card{background:var(--white);border-radius:12px;padding:22px;border:1.5px solid var(--border);display:flex;align-items:flex-start;gap:14px;box-shadow:var(--shadow);transition:border-color .2s,transform .2s}
.why-card:hover{border-color:var(--sky2);transform:translateY(-3px)}
.why-icon{width:46px;height:46px;flex-shrink:0;border-radius:11px;background:linear-gradient(135deg,var(--sky1),var(--sky2));display:flex;align-items:center;justify-content:center;font-size:1.25rem}
.why-card h4{font-size:.95rem;font-weight:800;color:var(--text);margin-bottom:4px}
.why-card p{font-size:.83rem;color:var(--text2);line-height:1.7}

/* ─── STEPS ─── */
.steps-wrap{background:linear-gradient(135deg,var(--sky1),var(--sky2));border-radius:var(--radius);padding:36px 28px;margin-top:40px}
.steps-wrap h3{color:#fff;font-size:1.2rem;font-weight:900;text-align:center;margin-bottom:24px}
.steps-g{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px}
.step-box{background:rgba(255,255,255,.16);border:1px solid rgba(255,255,255,.3);border-radius:12px;padding:22px 16px;text-align:center}
.step-n{width:44px;height:44px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:900;color:var(--sky1);margin:0 auto 12px}
.step-i{font-size:1.7rem;margin-bottom:8px}
.step-box h4{font-size:.9rem;font-weight:800;color:#fff;margin-bottom:5px}
.step-box p{font-size:.8rem;color:rgba(255,255,255,.88);line-height:1.6}

/* ─── DESTINATION ─── */
.region-head{display:flex;align-items:center;gap:10px;margin:40px 0 20px;padding-bottom:12px;border-bottom:2px solid var(--border)}
.region-head h2{font-size:1.2rem;font-weight:900;color:var(--text)}
.rbadge{padding:4px 14px;border-radius:50px;font-size:.78rem;font-weight:800;color:#fff;background:linear-gradient(135deg,var(--sky1),var(--sky2))}
.rbadge.g{background:linear-gradient(135deg,#2E7D32,#43A047)}
.rbadge.o{background:linear-gradient(135deg,#E65100,#F57C00)}
.rbadge.t{background:linear-gradient(135deg,#00695C,#26A69A)}

.dest-card{background:var(--white);border-radius:var(--radius);overflow:hidden;border:1.5px solid var(--border);box-shadow:var(--shadow);transition:transform .2s,box-shadow .2s}
.dest-card:hover{transform:translateY(-5px);box-shadow:0 12px 30px rgba(10,116,200,.16)}
.dest-img{position:relative;overflow:hidden}
.dest-img img{width:100%;height:200px;object-fit:cover;display:block;transition:transform .4s}
.dest-card:hover .dest-img img{transform:scale(1.05)}
.dest-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(5,20,45,.75) 0%,transparent 55%)}
.dest-lbl{position:absolute;bottom:0;left:0;right:0;padding:14px 16px}
.dest-tag{display:inline-block;padding:2px 9px;border-radius:50px;background:var(--sky1);color:#fff;font-size:.7rem;font-weight:800;margin-bottom:5px}
.dest-tag.g{background:#2E7D32}
.dest-tag.o{background:#E65100}
.dest-tag.t{background:#00695C}
.dest-name{color:#fff;font-size:1.1rem;font-weight:900}
.dest-sub{color:rgba(255,255,255,.85);font-size:.76rem;margin-top:1px}
.dest-body{padding:16px 18px}
.dest-body p{font-size:.85rem;color:var(--text2);line-height:1.75}
.dest-kws{display:flex;flex-wrap:wrap;gap:5px;margin-top:10px}
.kw{padding:2px 9px;border-radius:50px;background:#E3F3FD;color:var(--sky1);font-size:.73rem;font-weight:700}

/* ─── FLEET ─── */
.fleet-card{background:var(--white);border-radius:var(--radius);overflow:hidden;border:1.5px solid var(--border);box-shadow:var(--shadow);transition:transform .2s,box-shadow .2s}
.fleet-card:hover{transform:translateY(-5px);box-shadow:0 12px 28px rgba(10,116,200,.16)}
.fleet-img{height:195px;overflow:hidden;position:relative}
.fleet-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.fleet-card:hover .fleet-img img{transform:scale(1.05)}
.fleet-badge{position:absolute;top:12px;left:12px;padding:3px 11px;border-radius:50px;background:linear-gradient(135deg,var(--sky1),var(--sky2));color:#fff;font-size:.73rem;font-weight:800}
.fleet-body{padding:18px 20px}
.fleet-body h3{font-size:1rem;font-weight:800;color:var(--text);margin-bottom:6px}
.fleet-body p{font-size:.84rem;color:var(--text2);line-height:1.7;margin-bottom:12px}
.fleet-specs{display:flex;gap:12px;flex-wrap:wrap}
.fspec{font-size:.8rem;color:var(--text2);display:flex;align-items:center;gap:3px}
.fspec b{font-size:.95rem}

/* ─── AIRPORTS ─── */
.ac{background:var(--white);border-radius:12px;padding:15px 18px;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;box-shadow:var(--shadow);transition:border-color .2s}
.ac:hover{border-color:var(--sky2)}
.ac-l{display:flex;align-items:center;gap:12px}
.iata{font-size:1.2rem;font-weight:900;color:var(--sky1);min-width:50px}
.an{font-size:.92rem;font-weight:700;color:var(--text)}
.as{font-size:.76rem;color:var(--text3)}
.ab{padding:3px 12px;border-radius:50px;background:#E3F3FD;color:var(--sky1);font-size:.74rem;font-weight:800}

/* ─── PRICING ─── */
.price-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:20px}
.pc-card{background:var(--white);border-radius:var(--radius);padding:30px 24px;border:2px solid var(--border);box-shadow:var(--shadow);position:relative;transition:transform .2s}
.pc-card:hover{transform:translateY(-4px)}
.pc-card.pop{border-color:var(--sky1);background:linear-gradient(170deg,rgba(10,116,200,.04),var(--white))}
.pop-lbl{position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--sky1),var(--sky2));color:#fff;padding:4px 18px;border-radius:50px;font-size:.73rem;font-weight:800;white-space:nowrap}
.pt{font-size:.73rem;font-weight:800;color:var(--text3);text-transform:uppercase;letter-spacing:.09em;margin-bottom:4px}
.pc-card h3{font-size:1.15rem;font-weight:900;color:var(--text);margin-bottom:16px}
.pa{display:flex;align-items:baseline;gap:3px;margin-bottom:5px}
.pcu{font-size:.9rem;font-weight:700;color:var(--sky1);align-self:flex-start;margin-top:7px}
.pnum{font-size:2.7rem;font-weight:900;color:var(--sky1);line-height:1}
.punit{font-size:.82rem;color:var(--text3)}
.pnote{font-size:.78rem;color:var(--text3);margin-bottom:18px}
.plist{list-style:none;display:flex;flex-direction:column;gap:9px;margin-bottom:24px}
.plist li{display:flex;align-items:center;gap:8px;font-size:.87rem;color:var(--text2)}
.plist li::before{content:'✓';color:var(--sky1);font-weight:900;flex-shrink:0}
.btn-sky{display:block;padding:12px;border-radius:50px;background:linear-gradient(135deg,var(--sky1),var(--sky2));color:#fff;font-weight:800;text-align:center;font-size:.9rem;border:none;cursor:pointer;box-shadow:0 3px 12px rgba(10,116,200,.28);transition:transform .15s}
.btn-sky:hover{transform:translateY(-2px)}
.btn-sky-bdr{display:block;padding:11px;border-radius:50px;border:2px solid var(--sky1);color:var(--sky1);font-weight:800;text-align:center;font-size:.9rem;background:var(--white);cursor:pointer;transition:background .15s,color .15s}
.btn-sky-bdr:hover{background:var(--sky1);color:#fff}

/* ─── TESTIMONIALS ─── */
.tcard{background:var(--white);border-radius:var(--radius);padding:24px;border:1.5px solid var(--border);box-shadow:var(--shadow)}
.stars{color:var(--sun);font-size:1rem;margin-bottom:11px;letter-spacing:2px}
.ttext{font-size:.86rem;color:var(--text2);line-height:1.8;margin-bottom:16px;font-style:italic}
.tauthor{display:flex;align-items:center;gap:10px}
.tav{width:40px;height:40px;border-radius:50%;overflow:hidden;border:2px solid var(--border)}
.tav img{width:100%;height:100%;object-fit:cover}
.tname{font-size:.88rem;font-weight:800;color:var(--text)}
.tinfo{font-size:.74rem;color:var(--text3)}

/* ─── CONTACT ─── */
.contact-wrap{display:grid;grid-template-columns:1fr 1.15fr;gap:36px;align-items:start}
@media(max-width:800px){.contact-wrap{grid-template-columns:1fr}}
.ci-list{display:flex;flex-direction:column;gap:12px;margin-top:8px}
.ci-item{display:flex;align-items:flex-start;gap:12px;background:var(--white);border:1.5px solid var(--border);border-radius:12px;padding:16px;box-shadow:var(--shadow)}
.ci-icon{width:42px;height:42px;flex-shrink:0;border-radius:10px;background:linear-gradient(135deg,var(--sky1),var(--sky2));display:flex;align-items:center;justify-content:center;font-size:1.1rem}
.ci-item h4{font-size:.88rem;font-weight:800;color:var(--text);margin-bottom:2px}
.ci-item p,.ci-item a{font-size:.85rem;color:var(--text2)}
.ci-item a{color:var(--sky1)}
.form-box{background:var(--white);border-radius:var(--radius);padding:30px;border:1.5px solid var(--border);box-shadow:var(--shadow)}
.form-box h3{font-size:1.1rem;font-weight:900;color:var(--text);margin-bottom:20px}
.fg{margin-bottom:13px}
.fg label{display:block;font-size:.8rem;font-weight:800;color:var(--text);margin-bottom:4px}
.fg input,.fg select,.fg textarea{
  width:100%;padding:10px 13px;border-radius:8px;
  border:1.5px solid var(--border);background:var(--bg);
